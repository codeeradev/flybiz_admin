{
  "name": "flybiz",
  "type": "module",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=7.0.0",
    "npm": "please use pnpm"
  },
  "scripts": {
    "dev": "pnpm --filter @caffeine/template-frontend dev",
    "preview": "pnpm --filter @caffeine/template-frontend preview",
